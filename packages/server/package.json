    "@clerk/backend": "^3.2.8",
    "@hono/zod-validator": "^0.7.6",
    "@openrouter/ai-sdk-provider": "^2.9.1",
    "@polar-sh/sdk": "^0.47.1",
    "@sentry/bun": "^10.57.0",
    "@sentry/hono": "^10.57.0",
    "ai": "^6.0.205",
    "dotenv": "^17.4.1",
    "hono": "^4.12.12",
    "zod": "^4.3.6"
