{
  "name": "agenticcoder",
  "version": "1.0.0",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev:cli": "bun run --watch packages/cli/src/index.tsx",
    "dev:server": "bun run --hot packages/server/src/index.ts",
    "build:cli": "bun run --filter @agenticcoder/cli build",
    "link:cli": "bun run build:cli && cd packages/cli && bun link"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}